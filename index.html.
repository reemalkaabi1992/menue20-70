    function toggleLanguage() {
        currentLang = currentLang === 'ar' ? 'en' : 'ar';
        document.getElementById('htmlTag').dir = currentLang === 'ar' ? 'rtl' : 'ltr';
        const t = translations[currentLang];
        document.getElementById('langBtn').innerText = currentLang === 'ar' ? 'English' : 'عربي';
        document.getElementById('title').innerText = t.title;
        document.getElementById('subtitle').innerText = t.subtitle;
        document.getElementById('lblCustName').innerText = t.name;
        document.getElementById('lblDate').innerText = t.date;
        document.getElementById('lblLoc').innerText = t.loc;
        document.getElementById('lblMenu').innerText = t.menu;
        document.getElementById('optDefault').innerText = t.opt;
        document.getElementById('lblExtraTitle').innerText = t.extra;
        document.getElementById('btnSend').innerText = t.send;
        
        document.getElementById('opt20').innerText = t.m20;
        document.getElementById('opt30').innerText = t.m30;
        document.getElementById('opt40').innerText = t.m40;
        document.getElementById('opt50').innerText = t.m50;
        document.getElementById('opt60').innerText = t.m60;
        document.getElementById('opt70').innerText = t.m70;
        
        loadMenu();
    }

    function loadMenu() {
        const val = document.getElementById('menuSelect').value;
        const box = document.getElementById('menuContainer');
        if(!val) { box.style.display='none'; return; }
        box.style.display='block';
        const d = menus[val];
        renderS('mainsArea', translations[currentLang].mainT, 'M', d.mains[currentLang]);
        renderS('sidesArea', translations[currentLang].sideT, 'S', d.sides[currentLang]);
        renderS('sweetsArea', translations[currentLang].sweetT, 'W', d.sweets[currentLang]);
    }

    function renderS(id, title, prefix, groups) {
        let h = `<div class="section-title">${title}</div>`;
        groups.forEach((items, gI) => {
            const gId = `${prefix}_${gI}`;
            h += `<div class="sub-group">
                    <div class="group-number">${gI + 1}</div>
                    <span class="choose-hint">${translations[currentLang].hint}</span>`;
            items.forEach(it => {
                // النظام يتعرف على خيارات "مكس" لفتح خانة النص
                const isMix = it.includes("مكس") || it.includes("MIX 2 type");
                h += `<label class="option"><input type="radio" name="${gId}" value="${it}" onclick="toggleM('${gId}', ${isMix})"><span>${it}</span></label>`;
                if(isMix) h += `<div id="box_${gId}" class="mix-box"><input type="text" id="input_${gId}" placeholder="${translations[currentLang].mixPlc}"></div>`;
            });
            h += `</div>`;
        });
        document.getElementById(id).innerHTML = h;
    }

    function toggleM(gid, s) { 
        let b = document.getElementById(`box_${gid}`); 
        if(b) b.style.display = s ? 'block' : 'none'; 
    }

    function getF(id) {
        let t = ""; let i = 1;
        document.querySelectorAll(`#${id} input[type="radio"]:checked`).forEach(r => {
            let v = r.value; const m = document.getElementById(`input_${r.name}`);
            if(m && m.value && (v.includes("مكس") || v.includes("MIX 2 type"))) v += ` (${m.value})`;
            t += `${i}- ${v}%0a`; i++;
        });
        return t;
    }

    function sendWhatsApp() {
        const name = document.getElementById('custName').value;
        const menuS = document.getElementById('menuSelect');
        const menuT = menuS.options[menuS.selectedIndex].text;
        const date = document.getElementById('orderDate').value;
        const loc = document.getElementById('loc').value;
        if(!name || !menuS.value || !date || !loc) { alert(currentLang === 'ar' ? "أكمل البيانات" : "Please fill all fields"); return; }
        
        let msg = `*🍱 ${currentLang === 'ar' ? 'طلب حجز ريان ميني' : 'RYAN MINI Booking'}*%0a%0a👤 *${currentLang === 'ar' ? 'الاسم' : 'Name'}:* ${name}%0a👥 *${currentLang === 'ar' ? 'القائمة' : 'Menu'}:* ${menuT}%0a📅 *${currentLang === 'ar' ? 'التاريخ' : 'Date'}:* ${date}%0a📍 *${currentLang === 'ar' ? 'المنطقة' : 'Area'}:* ${loc}%0a%0a`;
        
        const m = getF('mainsArea'); if(m) msg += `*🍽 ${translations[currentLang].mainT}:*%0a${m}%0a`;
        const s = getF('sidesArea'); if(s) msg += `*🥗 ${translations[currentLang].sideT}:*%0a${s}%0a`;
        const w = getF('sweetsArea'); if(w) msg += `*🍰 ${translations[currentLang].sweetT}:*%0a${w}%0a`;
        
        const ex = document.getElementById('extraText').value; 
        if(ex.trim()) msg += `📝 *${currentLang === 'ar' ? 'ملاحظات' : 'Notes'}:* ${ex}`;
        
        window.open(`https://wa.me/971527024554?text=${msg}`, '_blank');
    }
