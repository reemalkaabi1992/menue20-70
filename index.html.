    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#6b7e5f">

    <style>
        :root { --olive: #6b7e5f; --brown: #8b4513; --beige: #f4eee4; --white: #ffffff; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background-color: var(--beige); color: #333; margin: 0; padding: 10px; line-height: 1.6; }
        
        /* الحاوية الرئيسية */
        .container { 
            max-width: 600px; background: var(--white); margin: 20px auto; 
            padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
            border-top: 12px solid var(--brown); 
        }

        /* زر تبديل اللغة */
        .lang-switch { text-align: left; margin-bottom: 15px; }
        .lang-btn { background: var(--olive); color: white; border: none; padding: 8px 18px; border-radius: 25px; cursor: pointer; font-weight: bold; font-size: 14px; transition: 0.3s; }
        .lang-btn:active { transform: scale(0.95); }
        
        .header { text-align: center; margin-bottom: 25px; border-bottom: 2px solid #eee; padding-bottom: 15px; }
        .header h2 { color: var(--brown); margin: 0; font-size: 28px; }
        .header p { color: #666; font-size: 15px; margin-top: 5px; }

        .field { margin-bottom: 20px; }
        label { display: block; font-weight: bold; margin-bottom: 8px; color: var(--brown); font-size: 15px; }
        input, select, textarea { width: 100%; padding: 14px; border: 1px solid #ddd; border-radius: 12px; font-size: 16px; background: #fafafa; transition: 0.3s; }
        input:focus, select:focus { border-color: var(--olive); outline: none; background: #fff; }
        
        /* تحريك ظهور المنيو */
        .menu-box { display: none; animation: fadeIn 0.5s ease forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .section-title { background: var(--olive); color: white; padding: 12px; border-radius: 10px; margin: 35px 0 15px 0; text-align: center; font-size: 18px; font-weight: bold; }
        
        /* تصميم المجموعات */
        .sub-group { background: #fff; border: 1px solid #eee; padding: 15px; border-radius: 15px; margin-bottom: 25px; position: relative; box-shadow: 0 2px 8px rgba(0,0,0,0.03); }
        .group-number { position: absolute; top: -15px; right: 15px; background: var(--brown); color: white; width: 32px; height: 32px; border-radius: 50%; text-align: center; line-height: 32px; font-weight: bold; font-size: 14px; }
        [dir="ltr"] .group-number { right: auto; left: 15px; }
        
        .choose-hint { font-size: 11px; color: #888; font-weight: normal; margin-right: 40px; display: block; margin-bottom: 5px; }
        [dir="ltr"] .choose-hint { margin-right: 0; margin-left: 40px; }
        
        .option { display: flex; align-items: center; padding: 12px; cursor: pointer; border-bottom: 1px solid #f9f9f9; transition: 0.2s; }
        .option:active { background: #f0f0f0; }
        .option span { flex: 1; }
        
        input[type="radio"] { width: 22px; height: 22px; margin-left: 15px; accent-color: var(--olive); cursor: pointer; }
        [dir="ltr"] input[type="radio"] { margin-left: 0; margin-right: 15px; }

        /* خانة كتابة الأصناف المختارة (للمكس) */
        .mix-box { display: none; margin-top: 10px; border: 2px dashed var(--olive); padding: 10px; border-radius: 10px; background: #fff; animation: slideDown 0.3s ease; }
        @keyframes slideDown { from { transform: translateY(-10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        .btn-send { 
            width: 100%; padding: 20px; background-color: #25D366; color: white; 
            border: none; border-radius: 15px; font-size: 20px; font-weight: bold; 
            cursor: pointer; margin-top: 30px; box-shadow: 0 5px 15px rgba(37,211,102,0.3); 
            transition: 0.3s;
        }
        .btn-send:active { transform: scale(0.98); box-shadow: none; }
    </style>
</head>
